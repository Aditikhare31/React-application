pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }   

        stage('Build') {
            steps {
                sh './build.sh'
            }
        }

        stage('Deploy to dev') {
            when {
                branch 'dev'
            }
            steps {
                sh './deploy.sh'
            }
        }

        stage('Deploy to Prod' {
            when {
                branch 'main'
            }
            steps {
                sh './deploy.sh'
            }
        }
    }  
}
